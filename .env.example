# ========================================
# Anthropic Claude API Key
# 获取地址：https://console.anthropic.com
# ========================================
ANTHROPIC_API_KEY=sk-xxx
# ========================================
ANTHROPIC_API_URL=xxx
# ========================================
# 模型选择（推荐 claude-sonnet-4-6，价格适中）
# claude-haiku-4-5-20251001   → 最便宜，速度最快
# claude-sonnet-4-6           → 性价比最佳（推荐）
# claude-opus-4-6             → 最聪明，最贵
# ========================================
MODEL_NAME=claude-sonnet-4-6

# ========================================
# 闲鱼 Cookie（从浏览器提取）
# 步骤：
#   1. 浏览器打开 https://www.goofish.com
#   2. 扫码登录
#   3. F12 → Network → 点任意请求 → Headers → 复制 Cookie 字段全部内容
# 注意：Cookie 约 7 天过期，过期需重新提取
# ========================================
COOKIES_STR=xxx

# ========================================
# 可选配置
# ========================================
# 切换人工模式的关键词（买家发送此词时暂停自动回复）
TOGGLE_KEYWORDS=。

# 模拟人工打字延迟（True/False）
SIMULATE_HUMAN_TYPING=True

# WebSocket 心跳间隔（秒）
HEARTBEAT_INTERVAL=15

# 日志级别（DEBUG/INFO/WARNING）
LOG_LEVEL=INFO
API_KEY='sk-xxx'

# ========================================
# 议价规则配置（只改这里，无需动代码）
# 比例说明：0.9 = 原价的 90%，0.8 = 原价的 80%
# ========================================
# 轻松接受线：买家出价 ≥ 此比例，直接同意
PRICE_EASY_RATIO=0.9
# 最低底线：买家出价低于此比例，坚决拒绝
PRICE_FLOOR_RATIO=0.8
